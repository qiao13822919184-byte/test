---
// 🌟 这里的魔法升级了：改用 import.meta.glob，它比 Astro.glob 更稳定
// 1. 扫描当前文件夹下的所有 .md 文件
const postFiles = import.meta.glob('./*.md', { eager: true });

// 2. 把扫描到的对象转换成数组，并提取出内容
const posts = Object.values(postFiles);

// 3. 排序逻辑（保持不变）
posts.sort((a, b) => {
  const dateA = a.frontmatter.date ? Date.parse(a.frontmatter.date) : 0;
  const dateB = b.frontmatter.date ? Date.parse(b.frontmatter.date) : 0;
  return dateB - dateA;
});
---

---
// src/pages/index.astro
import products from '../data/products.json';
// 1. 引入基础布局骨架
import BaseLayout from '../layouts/BaseLayout.astro';
---

<html lang="zh">
  <head>
    <meta charset="utf-8" />
    <title>企业介绍</title>
    <style>
      body { max-width: 800px; margin: 0 auto; font-family: sans-serif; }
      .post-card { 
        border: 1px solid #eee; 
        padding: 15px; 
        margin-bottom: 15px; 
        border-radius: 8px;
        transition: box-shadow 0.3s;
      }
      .post-card:hover { box-shadow: 0 4px 8px rgba(0,0,0,0.1); }
      .post-title { font-size: 1.5em; margin: 0 0 10px 0; }
      .post-title a { text-decoration: none; color: #333; }
      .post-title a:hover { color: #007bff; }
      .post-meta { color: #666; font-size: 0.9em; }
    </style>
  </head>
  <body>
    <a href={`${base}/`}>回到首页</a>
    
    <h1>最新博客文章</h1>

    <div class="post-list">
      <!-- 循环遍历扫描到的文章数组 -->
      {posts.map((post) => (
        <div class="post-card">
          <h2 class="post-title">
            <!-- post.url 是 Astro 自动生成的文章网址！ -->
            <!-- post.frontmatter 里面包含了你在 md 文件顶部写的 title 和 date -->
            <a href={post.url}>{post.frontmatter.title}</a>
          </h2>
          <div class="post-meta">发布日期: {post.frontmatter.date}</div>
        </div>
      ))}
    </div>

  </body>
</html>
