---
// src/pages/index.astro
import products from '../data/products.json';
import BaseLayout from '../layouts/BaseLayout.astro';

// 🌟 获取你在 astro.config.mjs 中配置的 base 路径（即 '/test'）
const baseUrl = import.meta.env.BASE_URL;
---

<BaseLayout title="首页">
  
  <h1>欢迎来到我的商店</h1>

  <div class="product-list">
    {products.map((item) => (
      <div class="product-card" style="border: 1px solid #ccc; padding: 15px; margin: 10px 0;">
        <h2>{item.name}</h2>
        <p>价格: ${item.price}</p>
        <p>{item.desc}</p>
        
        {/* 🌟 核心修改：在路径前加上变量。注意这里使用了模板字符串 `${}` */}
        <a href={`${baseUrl}/products/${item.id}`}>查看详情</a>
      </div>
    ))}
  </div>

  <hr />
  <p>想了解更多？去看看我们的 <a href={`${baseUrl}/blog`}>博客列表</a></p>

</BaseLayout>
